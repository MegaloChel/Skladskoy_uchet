<Window x:Class="WpfApp22.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="СКЛАДСКОЙ УЧЁТ - Полный доступ"
        Height="750" Width="1300"
        WindowStartupLocation="CenterScreen">
    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Z" Modifiers="Control+Shift" Command="{Binding RedoCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <SolidColorBrush x:Key="AppBg" Color="#F5F7FB"/>
        <SolidColorBrush x:Key="CardBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Primary" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryDark" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="Muted" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#E2E8F0"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Primary}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryDark}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryDark}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#EEF2FF"/>
                        <Setter Property="Foreground" Value="#1E293B"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="Padding" Value="10,8"/>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>
    <Grid Background="{StaticResource AppBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Шапка (только обновление и статус) -->
        <Border Grid.Row="0" Background="#0F172A" Padding="16" Margin="8,8,8,4" CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="📦 СКЛАДСКОЙ УЧЁТ"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <Button Content="🔄 Обновить всё"
                            Command="{Binding RefreshCommand}"
                            Padding="10,5"
                            Margin="20,0,0,0"
                            VerticalAlignment="Center"/>
                <Button Content="↶ Undo" Command="{Binding UndoCommand}" Margin="12,0,0,0" Padding="10,5" VerticalAlignment="Center"/>
                    <Button Content="↷ Redo" Command="{Binding RedoCommand}" Margin="8,0,0,0" Padding="10,5" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основные вкладки -->
        <TabControl Grid.Row="1" Margin="8,4,8,8" x:Name="MainTabs">

            <!-- Вкладка Товары -->
            <TabItem Header="🗃️ Товары">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Панель поиска -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                        <TextBlock Text="Поиск товара:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Grid Width="300">
                            <TextBox x:Name="SearchBox" Padding="5" TextChanged="SearchBox_TextChanged" Background="White"/>
                            <TextBlock Text="Введите название или артикул..."
                                       Foreground="Gray"
                                       Margin="7,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </StackPanel>

                    <!-- Кнопка сохранения товаров -->
                    <Border Grid.Row="1" Background="{StaticResource CardBg}" Padding="10" Margin="6" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Сохранить изменения в товарах"
                                    Command="{Binding SaveProductsCommand}"
                                    FontWeight="Bold" 
                                    Padding="15,5"/>
                            <TextBlock Text="* После сохранения новые товары появятся в выпадающих списках"
                                       Foreground="#7f8c8d"
                                       VerticalAlignment="Center"
                                       Margin="20,0,0,0"
                                       FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="2"
                              x:Name="GridТовары"
                              PreviewKeyDown="DataGrid_PreviewKeyDown"
                              AutoGenerateColumns="False"
                              CanUserAddRows="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Binding="{Binding Id}" IsReadOnly="True" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Название}" Width="*"/>
                            <DataGridTextColumn Header="Артикул" Binding="{Binding Артикул}" Width="150"/>
                            <DataGridTextColumn Header="Категория" Binding="{Binding Категория}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка Склады -->
            <TabItem Header="🏢 Склады">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Кнопка сохранения складов -->
                    <Border Grid.Row="0" Background="{StaticResource CardBg}" Padding="10" Margin="6" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Сохранить изменения в складах"
                                    Command="{Binding SaveWarehousesCommand}"
                                    FontWeight="Bold" 
                                    Padding="15,5"/>
                            <TextBlock Text="* После сохранения новые склады появятся в выпадающих списках"
                                       Foreground="#7f8c8d"
                                       VerticalAlignment="Center"
                                       Margin="20,0,0,0"
                                       FontStyle="Italic"/>
                            <Grid Width="260" Margin="20,0,0,0">
                                <TextBox x:Name="SearchСклады" Padding="6" TextChanged="SearchСклады_TextChanged" ToolTip="Поиск по складам"/>
                                <TextBlock Text="Введите название или адрес..."
                                           Foreground="Gray"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchСклады}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1"
                              x:Name="GridСклады"
                              PreviewKeyDown="DataGrid_PreviewKeyDown"
                              AutoGenerateColumns="False"
                              CanUserAddRows="True"
                              Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Binding="{Binding Id}" IsReadOnly="True" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Название}" Width="*"/>
                            <DataGridTextColumn Header="Адрес" Binding="{Binding Адрес}" Width="300"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка Поставщики -->
            <TabItem Header="🚚 Поставщики">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Кнопка сохранения поставщиков -->
                    <Border Grid.Row="0" Background="{StaticResource CardBg}" Padding="10" Margin="6" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Сохранить изменения в поставщиках"
                                    Command="{Binding SaveSuppliersCommand}"
                                    FontWeight="Bold" 
                                    Padding="15,5"/>
                            <TextBlock Text="* После сохранения новые поставщики появятся в выпадающих списках"
                                       Foreground="#7f8c8d"
                                       VerticalAlignment="Center"
                                       Margin="20,0,0,0"
                                       FontStyle="Italic"/>
                            <Grid Width="260" Margin="20,0,0,0">
                                <TextBox x:Name="SearchПоставщики" Padding="6" TextChanged="SearchПоставщики_TextChanged" ToolTip="Поиск по поставщикам"/>
                                <TextBlock Text="Введите название или контакты..."
                                           Foreground="Gray"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchПоставщики}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="1"
                              x:Name="GridПоставщики"
                              PreviewKeyDown="DataGrid_PreviewKeyDown"
                              AutoGenerateColumns="False"
                              CanUserAddRows="True"
                              Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Binding="{Binding Id}" IsReadOnly="True" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Название}" Width="*"/>
                            <DataGridTextColumn Header="Контакты" Binding="{Binding Контакты}" Width="300"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка Остатки (с резервом) -->
            <TabItem Header="📊 Остатки">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Панель управления остатками -->
                    <Border Grid.Row="0" Background="{StaticResource CardBg}" Padding="10" Margin="6" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="ℹ" Foreground="#3498db" FontSize="16"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Остатки рассчитываются автоматически. Для резерва выберите строку."
                                           VerticalAlignment="Center"
                                           Foreground="#7f8c8d"/>
                                <Grid Width="280" Margin="14,0,0,0">
                                    <TextBox x:Name="SearchОстатки" Padding="6" TextChanged="SearchОстатки_TextChanged" ToolTip="Поиск по остаткам"/>
                                    <TextBlock Text="Введите товар или склад..."
                                               Foreground="Gray"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=SearchОстатки}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Command="{Binding ReserveCommand}"
                                        ToolTip="Зарезервировать выбранный товар"
                                        Padding="10,5"
                                        Background="#f39c12"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔒" FontSize="14" Margin="0,0,5,0"/>
                                        <TextBlock Text="Резерв" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding UnreserveCommand}"
                                        ToolTip="Снять часть товара с резерва"
                                        Padding="10,5"
                                        Background="#f59e0b"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔓" FontSize="14" Margin="0,0,5,0"/>
                                        <TextBlock Text="Снять резерв" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding FullRecountCommand}"
                                        ToolTip="Полная очистка и пересчёт остатков"
                                        Padding="10,5"
                                        Background="#3498db"
                                        Foreground="White"
                                        BorderThickness="0"
                                        Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="↻" FontSize="14" Margin="0,0,5,0"/>
                                        <TextBlock Text="Пересчитать" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              x:Name="GridОстатки"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Товар" Binding="{Binding Товар.Название}" Width="250"/>
                            <DataGridTextColumn Header="Склад" Binding="{Binding Склад.Название}" Width="200"/>
                            <DataGridTextColumn Header="Количество" Binding="{Binding Количество}" Width="80"/>
                            <DataGridTextColumn Header="В резерве" Binding="{Binding В_Резерве}" Width="80"/>
                            <DataGridTextColumn Header="Доступно" Binding="{Binding Доступно}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Доступно}" Value="0">
                                                <Setter Property="Background" Value="#FFE0E0"/>
                                                <Setter Property="Foreground" Value="Red"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка Приход -->
            <TabItem Header="📥 Приход">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Фильтры -->
                    <Border Grid.Row="0" Background="{StaticResource CardBg}" Padding="10" Margin="6" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Фильтр по дате:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="с:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <DatePicker x:Name="ПриходДатаС" Width="120" SelectedDateChanged="ФильтрПриход_Changed"/>
                            <TextBlock Text="по:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                            <DatePicker x:Name="ПриходДатаПо" Width="120" SelectedDateChanged="ФильтрПриход_Changed"/>
                            <Button Content="✕ Сбросить" Margin="10,0,0,0" Command="{Binding ResetIncomeFilterCommand}" Padding="8,3"/>
                            <Grid Width="240" Margin="16,0,0,0">
                                <TextBox x:Name="SearchПриход" Padding="6" TextChanged="SearchПриход_TextChanged" ToolTip="Поиск по приходу"/>
                                <TextBlock Text="Введите товар, склад, поставщика..."
                                           Foreground="Gray"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchПриход}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Кнопка сохранения прихода -->
                    <Border Grid.Row="1" Background="{StaticResource CardBg}" Padding="10" Margin="6" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Сохранить приход"
                                    Command="{Binding SaveIncomeCommand}"
                                    FontWeight="Bold" 
                                    Padding="15,5"/>
                            <TextBlock Text="* После сохранения автоматически пересчитываются остатки"
                                       Foreground="#7f8c8d"
                                       VerticalAlignment="Center"
                                       Margin="20,0,0,0"
                                       FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="2"
                              x:Name="GridПриход"
                              PreviewKeyDown="DataGrid_PreviewKeyDown"
                              AutoGenerateColumns="False"
                              CanUserAddRows="True"
                              Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Binding="{Binding Id}" IsReadOnly="True" Width="50"/>
                            <DataGridComboBoxColumn Header="Товар (артикул)"
                                                    SelectedValueBinding="{Binding ТоварId}"
                                                    SelectedValuePath="Id"
                                                    DisplayMemberPath="ПредставлениеДляВыбора"
                                                    Width="250"/>
                            <DataGridComboBoxColumn Header="Склад"
                                                    SelectedValueBinding="{Binding СкладId}"
                                                    SelectedValuePath="Id"
                                                    DisplayMemberPath="Название"
                                                    Width="150"/>
                            <DataGridComboBoxColumn Header="Поставщик"
                                                    SelectedValueBinding="{Binding ПоставщикId}"
                                                    SelectedValuePath="Id"
                                                    DisplayMemberPath="Название"
                                                    Width="200"/>
                            <DataGridTextColumn Header="Количество" Binding="{Binding Количество}" Width="100"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Цена, StringFormat='{}{0:N2}'}" Width="100"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding Дата, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка Расход -->
            <TabItem Header="📤 Расход">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Фильтры -->
                    <Border Grid.Row="0" Background="{StaticResource CardBg}" Padding="10" Margin="6" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Фильтр по дате:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="с:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <DatePicker x:Name="РасходДатаС" Width="120" SelectedDateChanged="ФильтрРасход_Changed"/>
                            <TextBlock Text="по:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                            <DatePicker x:Name="РасходДатаПо" Width="120" SelectedDateChanged="ФильтрРасход_Changed"/>
                            <Button Content="✕ Сбросить" Margin="10,0,0,0" Command="{Binding ResetOutcomeFilterCommand}" Padding="8,3"/>
                            <Grid Width="240" Margin="16,0,0,0">
                                <TextBox x:Name="SearchРасход" Padding="6" TextChanged="SearchРасход_TextChanged" ToolTip="Поиск по расходу"/>
                                <TextBlock Text="Введите товар, склад или причину..."
                                           Foreground="Gray"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchРасход}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Кнопка сохранения расхода -->
                    <Border Grid.Row="1" Background="{StaticResource CardBg}" Padding="10" Margin="6" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Сохранить расход"
                                    Command="{Binding SaveOutcomeCommand}"
                                    FontWeight="Bold" 
                                    Padding="15,5"/>
                            <TextBlock Text="* После сохранения автоматически пересчитываются остатки"
                                       Foreground="#7f8c8d"
                                       VerticalAlignment="Center"
                                       Margin="20,0,0,0"
                                       FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="2"
                              x:Name="GridРасход"
                              PreviewKeyDown="DataGrid_PreviewKeyDown"
                              AutoGenerateColumns="False"
                              CanUserAddRows="True"
                              Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№" Binding="{Binding Id}" IsReadOnly="True" Width="50"/>
                            <DataGridComboBoxColumn Header="Товар (артикул)"
                                                    SelectedValueBinding="{Binding ТоварId}"
                                                    SelectedValuePath="Id"
                                                    DisplayMemberPath="ПредставлениеДляВыбора"
                                                    Width="250"/>
                            <DataGridComboBoxColumn Header="Склад"
                                                    SelectedValueBinding="{Binding СкладId}"
                                                    SelectedValuePath="Id"
                                                    DisplayMemberPath="Название"
                                                    Width="150"/>
                            <DataGridTextColumn Header="Количество" Binding="{Binding Количество}" Width="100"/>
                            <DataGridTextColumn Header="Причина" Binding="{Binding Причина}" Width="*"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding Дата, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Width="130"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Новая вкладка: Отчёты -->
            <TabItem Header="📈 Отчёты">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Панель формирования отчёта -->
                    <Border Grid.Row="0" Background="{StaticResource CardBg}" Padding="10" Margin="6" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Период отчёта (необязательно):" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="с:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <DatePicker x:Name="ОтчетДатаС" Width="120"/>
                            <TextBlock Text="по:" VerticalAlignment="Center" Margin="10,0,5,0"/>
                            <DatePicker x:Name="ОтчетДатаПо" Width="120"/>
                            <Grid Width="220" Margin="16,0,0,0">
                                <TextBox x:Name="SearchОтчет" Padding="6" TextChanged="SearchОтчет_TextChanged" ToolTip="Поиск по отчёту"/>
                                <TextBlock Text="Введите товар, тип или контрагента..."
                                           Foreground="Gray"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchОтчет}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Button Content="📊 Сформировать отчёт / историю"
                                    Command="{Binding BuildReportCommand}"
                                    Padding="15,5"
                                    Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="1" Text="Движение товара за период:" FontWeight="Bold" Margin="10,5,0,5"/>

                    <DataGrid Grid.Row="2"
                              x:Name="GridОтчет"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Margin="5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding Дата, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}" Width="130"/>
                            <DataGridTextColumn Header="Товар" Binding="{Binding Товар}" Width="200"/>
                            <DataGridTextColumn Header="Склад" Binding="{Binding Склад}" Width="150"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding Тип}" Width="80"/>
                            <DataGridTextColumn Header="Кол-во" Binding="{Binding Количество}" Width="80"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Цена, StringFormat='{}{0:N2}'}" Width="100"/>
                            <DataGridTextColumn Header="Контрагент" Binding="{Binding Контрагент}" Width="220"/>
                            <DataGridTextColumn Header="Основание операции" Binding="{Binding ОснованиеОперации}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Строка состояния -->
        <StatusBar Grid.Row="2" Margin="8,0,8,8" Background="White" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" FontWeight="Bold"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
